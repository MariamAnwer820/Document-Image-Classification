# ==============================================================================
#  Document Image Classification — Unified Environment Configuration
# ==============================================================================
#  Project : Multimodal Document Image Classification (CNN + OCR Fusion)
#  Dataset : RVL-CDIP (16 document classes, preprocessed with Deskew + CLAHE)
#  Branches: CNN (CustomCNN, MobileNetV2, EfficientNet-B0) + OCR (Tesseract + SBERT)
#  Fusion  : Score-level, Feature-level, Meta-learning, Specialist overrides
#
#  HOW TO USE
#  ----------
#  1. Copy this file to .env in your project root.
#  2. Update all REQUIRED paths to match your local environment.
#  3. Adjust optional parameters before running notebooks.
#  4. Load variables in Python with:
#       from dotenv import load_dotenv
#       load_dotenv()
#       import os
#       DATA_DIR = os.environ["DATA_DIR"]
#
#  NOTE: Boolean values use True/False strings — parse with:
#       os.getenv("KEY") == "True"
#  Comma-separated lists — parse with:
#       os.getenv("KEY").split(",")
# ==============================================================================


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 1: GLOBAL SETTINGS
#  Shared across all branches (CNN, OCR, Fusion).
# ═══════════════════════════════════════════════════════════════════════════════

# Random seed for reproducibility (Python, NumPy, PyTorch, sklearn, random)
RANDOM_SEED=42

# Compute device: "auto" (auto-detect CUDA/CPU), "cuda", or "cpu"
DEVICE=auto

# Number of document classes in the dataset
NUM_CLASSES=16

# Recognized image file extensions (comma-separated) used when scanning folders
IMAGE_EXTS=.jpg,.jpeg,.png,.tif,.tiff,.bmp,.gif


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 2: PATHS (REQUIRED — edit before first run)
#  All directory and file paths used by the notebooks.
#  UPDATE THESE to match your local environment before running.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Data directories ──

# Root folder that contains the preprocessed train/val/test split folders
# Expected subfolders: {SPLIT_OUTPUT_DIR}/train/, {SPLIT_OUTPUT_DIR}/val/, {SPLIT_OUTPUT_DIR}/test/
# Also used as the OCR data directory (same images, different processing)
SPLIT_OUTPUT_DIR=C:\Users\CHANGE_ME\project\rvlcdip\CNN_preprocessed
DATA_DIR=C:\Users\CHANGE_ME\project\rvlcdip\CNN_preprocessed

# Main fusion data folder (contains prediction files, features, etc.)
FUSION_DIR=/path/to/your/fusion

# Tobacco-3482 dataset folder (optional, for additional evaluation)
TOBACCO_DIR=/path/to/tobacco3482

# ── Output directories ──

# Directory where trained model weights (.pth) and config files (.json) are saved
MODEL_EXPORT_DIR=C:\Users\CHANGE_ME\project\rvlcdip\saved_models

# Output directory for experiment results (CSV, JSON metrics)
RESULTS_DIR=results

# Output directory for all plots and figures
FIGURES_DIR=figures

# Sub-directory for EDA (Exploratory Data Analysis) visualizations
FIGURES_EDA_DIR=figures/eda

# ── OCR-specific directories ──

# Directory where OCR JSON caches and .npy embedding files are stored
OCR_CACHE_DIR=ocr_cache

# Full path to the Tesseract executable
# Windows default : C:\Users\<name>\AppData\Local\Programs\Tesseract-OCR\tesseract.exe
# Linux           : /usr/bin/tesseract   (run `which tesseract` to confirm)
# macOS (Homebrew): /opt/homebrew/bin/tesseract
TESS_PATH=C:\Users\CHANGE_ME\AppData\Local\Programs\Tesseract-OCR\tesseract.exe


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 3: DATASET
#  Configuration for the RVL-CDIP document image dataset.
# ═══════════════════════════════════════════════════════════════════════════════

# Maximum number of images to load per class (leave empty or set to 0 to use all images)
SAMPLES_PER_CLASS=


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 4: IMAGE PREPROCESSING
#  Image resolution, CLAHE contrast enhancement, adaptive thresholding,
#  and morphological operations applied during data loading.
# ═══════════════════════════════════════════════════════════════════════════════

# Input image resolution (height = width). All images are resized to IMG_SIZE x IMG_SIZE.
# Must match the model's expected input dimensions (224 for MobileNetV2 / EfficientNet-B0).
IMG_SIZE=224

# Resize dimension applied before CenterCrop during validation/test transforms
RESIZE_BEFORE_CROP=256

# CLAHE (Contrast Limited Adaptive Histogram Equalization) parameters
# Applied to ALL images (train + val + test) via apply_clahe_tensor()
CLAHE_CLIP_LIMIT=2.0
CLAHE_TILE_GRID_SIZE=8

# Adaptive Gaussian Thresholding parameters
# Applied only to TRAINING images via apply_adaptive_threshold()
# Blended with original: TEXT_BLEND_ORIGINAL * img + TEXT_BLEND_ENHANCED * thresholded
ADAPTIVE_THRESH_BLOCK_SIZE=11
ADAPTIVE_THRESH_C=2

# Morphological closing applied after adaptive thresholding to clean text regions
MORPH_KERNEL_SIZE=2
MORPH_ITERATIONS=1

# Blend ratios for mixing the original image with the adaptively thresholded result
# Final image = TEXT_BLEND_ORIGINAL * original + TEXT_BLEND_ENHANCED * enhanced
TEXT_BLEND_ORIGINAL=0.7
TEXT_BLEND_ENHANCED=0.3


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 5: NORMALIZATION
#  Channel-wise mean and std for image normalization.
#  Two presets: ImageNet stats for pretrained models, standard 0.5 for scratch CNN.
# ═══════════════════════════════════════════════════════════════════════════════

# ImageNet statistics — used for MobileNetV2 and EfficientNet-B0 (pretrained)
NORM_MEAN_PRETRAINED=0.485,0.456,0.406
NORM_STD_PRETRAINED=0.229,0.224,0.225

# Standard normalization — used for CustomCNN (trained from scratch)
NORM_MEAN_CUSTOM=0.5,0.5,0.5
NORM_STD_CUSTOM=0.5,0.5,0.5


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 6: DATA AUGMENTATION (Training Only)
#  All augmentation is applied exclusively during training.
#  Validation/test uses only resize + center crop + CLAHE + normalize.
# ═══════════════════════════════════════════════════════════════════════════════

# ColorJitter — random brightness, contrast, and saturation adjustments
AUG_BRIGHTNESS=0.25
AUG_CONTRAST=0.25
AUG_SATURATION=0.15

# RandomAffine — rotation and translation
AUG_ROTATION=10
AUG_TRANSLATE_H=0.03
AUG_TRANSLATE_V=0.03

# RandomResizedCrop — random zoom and aspect ratio variation
RANDOM_RESIZED_CROP_SCALE_MIN=0.8
RANDOM_RESIZED_CROP_SCALE_MAX=1.0
RANDOM_RESIZED_CROP_RATIO_MIN=0.9
RANDOM_RESIZED_CROP_RATIO_MAX=1.1

# RandomHorizontalFlip — probability of flipping the image horizontally
RANDOM_HFLIP_P=0.3

# GaussianBlur — applied via RandomApply (probabilistic)
GAUSSIAN_BLUR_KERNEL=3
GAUSSIAN_BLUR_SIGMA_MIN=0.1
GAUSSIAN_BLUR_SIGMA_MAX=1.5
GAUSSIAN_BLUR_APPLY_P=0.3

# RandomErasing — randomly masks a rectangular region of the image
RANDOM_ERASING_P=0.15
RANDOM_ERASING_SCALE_MIN=0.02
RANDOM_ERASING_SCALE_MAX=0.15


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 7: MIXUP
#  MixUp data augmentation — blends pairs of images and their labels.
#  Only used for the CustomCNN (scratch training). Pretrained models do NOT use MixUp.
# ═══════════════════════════════════════════════════════════════════════════════

# Beta distribution alpha parameter. Higher = stronger mixing. 0 = disabled.
MIXUP_ALPHA=0.2


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 8: TEST-TIME AUGMENTATION (TTA)
#  Generates multiple augmented views of each test image and averages predictions.
#  Tighter ranges than training augmentation to stay close to the original image.
# ═══════════════════════════════════════════════════════════════════════════════

# Enable/disable TTA evaluation after training
USE_TTA=True

# Number of augmented views to generate and average per test image
TTA_ROUNDS=5

# TTA crop scale and aspect ratio (tighter than training to reduce distortion)
TTA_CROP_SCALE_MIN=0.85
TTA_CROP_SCALE_MAX=1.0
TTA_CROP_RATIO_MIN=0.95
TTA_CROP_RATIO_MAX=1.05

# TTA flip and color jitter (lighter than training)
TTA_HFLIP_P=0.5
TTA_COLOR_JITTER_BRIGHTNESS=0.1
TTA_COLOR_JITTER_CONTRAST=0.1


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 9: CNN TRAINING — Global Settings
#  Core training hyperparameters shared across all three CNN models.
# ═══════════════════════════════════════════════════════════════════════════════

# Batch size for all DataLoaders (train, val, test)
# Reduce to 32 or 16 if you run out of GPU memory
BATCH_SIZE=64

# L2 regularization strength applied via the Adam optimizer
WEIGHT_DECAY=0.0005

# Label smoothing factor in CrossEntropyLoss (reduces overconfidence)
LABEL_SMOOTHING=0.05

# Maximum gradient norm for gradient clipping (prevents exploding gradients)
GRAD_CLIP_NORM=1.0

# Optimizer type (currently only Adam is implemented)
OPTIMIZER=Adam

# Differential learning rate ratio for pretrained models:
# backbone_lr = full_lr * DIFFERENTIAL_LR_RATIO, head_lr = full_lr
# Only applies to MobileNetV2 and EfficientNet-B0
DIFFERENTIAL_LR_RATIO=0.05

# Learning rate scheduler type (currently only CosineAnnealingLR after warmup)
LR_SCHEDULER=CosineAnnealingLR

# Minimum LR for cosine annealing (LR decays to this value)
COSINE_ANNEALING_ETA_MIN=0.000001

# Number of warmup epochs where LR linearly increases from 0 to target LR
WARMUP_EPOCHS=2

# DataLoader workers. Set to 0 on Windows to avoid multiprocessing issues;
# set to 4-8 on Linux for faster data loading
NUM_WORKERS=0

# Pin memory for faster GPU transfer. Set to "auto" to enable only when using CUDA
PIN_MEMORY=auto


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 10: CNN TRAINING — Per-Model Epochs & Early Stopping
#  Each model has its own epoch budget and patience.
#  Early stopping triggers when validation accuracy does not improve for
#  PATIENCE consecutive epochs.
# ═══════════════════════════════════════════════════════════════════════════════

# CustomCNN (scratch) — needs more epochs to converge
NUM_EPOCHS=30
PATIENCE=8

# MobileNetV2 (pretrained) — converges faster due to transfer learning
MOBILENET_EPOCHS=25
MOBILENET_PATIENCE=5

# EfficientNet-B0 (pretrained) — given more budget for potentially better accuracy
EFFICIENTNET_EPOCHS=40
EFFICIENTNET_PATIENCE=7


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 11: CNN TRAINING — Learning Rates
#  Separate LR settings for scratch vs. pretrained models.
# ═══════════════════════════════════════════════════════════════════════════════

# Learning rate for CustomCNN trained from scratch (higher LR needed)
LEARNING_RATE_SCRATCH=0.001

# Learning rate for pretrained models (lower LR to preserve learned features)
LEARNING_RATE_PRETR=0.0005


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 12: FREEZE & STOCHASTIC WEIGHT AVERAGING (SWA)
#  Backbone freezing for pretrained models and SWA for final model polishing.
# ═══════════════════════════════════════════════════════════════════════════════

# Freeze backbone (feature extractor) for the first N epochs in pretrained models.
# Only the classifier head trains during this period, then the backbone unfreezes.
# CustomCNN is never frozen (trained from scratch).
FREEZE_UNTIL_EPOCH=3

# Epoch at which Stochastic Weight Averaging begins.
# SWA averages model weights over the remaining epochs for a smoother final model.
# Only triggered if the current epoch >= SWA_START_EPOCH.
SWA_START_EPOCH=20

# SWA learning rate (very low — only small weight updates during averaging)
SWA_LR=0.00002


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 13: MODEL ARCHITECTURE — CustomCNN (Scratch)
#  A simple 3-block CNN with progressive channel depth: 32 -> 64 -> 128.
#  All convolutions use 3x3 kernels with padding=1 and MaxPool2d(2,2).
#  Spatial resolution: 224 -> 112 -> 56 -> 28 -> AdaptiveAvgPool -> 1x1.
# ═══════════════════════════════════════════════════════════════════════════════

# Parameter name prefix used to identify backbone layers for differential LR
CUSTOM_CNN_BACKBONE_PARAM_NAME=block

# Whether MixUp augmentation is used during CustomCNN training
CUSTOM_CNN_USE_MIXUP=True


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 14: MODEL ARCHITECTURE — Pretrained Heads (MobileNetV2 & EfficientNet-B0)
#  Both models share the same custom classifier head structure:
#    Dropout -> Linear(1280, FC1) -> BN -> ReLU -> Dropout -> Linear(FC1, FC2)
#    -> BN -> ReLU -> Dropout -> Linear(FC2, NUM_CLASSES)
# ═══════════════════════════════════════════════════════════════════════════════

# Parameter name prefix used to identify backbone/feature layers
PRETRAINED_BACKBONE_PARAM_NAME=features

# Whether MixUp is used during pretrained model training (should be False)
PRETRAINED_USE_MIXUP=False

# Fully-connected layer sizes in the custom head (comma-separated)
# The head structure is: Linear(in_features, FC1) -> Linear(FC1, FC2) -> Linear(FC2, NUM_CLASSES)
# in_features is 1280 for both MobileNetV2 and EfficientNet-B0
HEAD_FC_SIZES=1024,512

# Dropout probabilities at each stage of the classifier head
HEAD_DROPOUT_1=0.4
HEAD_DROPOUT_2=0.3
HEAD_DROPOUT_3=0.2


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 15: HARD CLASS BOOST
#  Multiplier applied to class weights for classes that are historically
#  difficult to classify. After computing inverse-frequency class weights,
#  these classes get their weight multiplied by the boost factor.
#  This helps the model pay more attention to confusing document types.
# ═══════════════════════════════════════════════════════════════════════════════

# ScientificReport is the hardest class (most confusion with other text-heavy docs)
HARD_CLASS_BOOST_ScientificReport=2.5

# Memo is often confused with Letter and Email
HARD_CLASS_BOOST_Memo=1.8

# Form, Questionnaire, Budget, and Invoice are moderately difficult
HARD_CLASS_BOOST_Form=1.5
HARD_CLASS_BOOST_Questionnaire=1.5
HARD_CLASS_BOOST_Budget=1.5
HARD_CLASS_BOOST_Invoice=1.5


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 16: ENSEMBLE & ABLATION
# ═══════════════════════════════════════════════════════════════════════════════

# ── Ensemble ──

# Ensemble strategy: "weighted_avg" (weight by individual model accuracy)
ENSEMBLE_METHOD=weighted_avg

# Models included in the ensemble (comma-separated)
ENSEMBLE_MODELS=CustomCNN,MobileNetV2,EfficientNetB0

# ── Ablation Study ──

# Model used for the ablation study (same head structure as main training)
ABLATION_MODEL=MobileNetV2

# Ablation epoch budget and patience (matches MOBILENET_EPOCHS / MOBILENET_PATIENCE)
ABLATION_EPOCHS=25
ABLATION_PATIENCE=5


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 17: OCR PIPELINE
#  Tesseract OCR, SBERT embeddings, multi-crop visual features, SVM classifier,
#  and specialist binary classifiers for confused class pairs.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Tesseract OCR ──

# Tesseract OCR engine config string passed to pytesseract.
# --oem 3  = best available LSTM engine
# --psm 6  = assume a single uniform block of text
# -l eng   = English language pack (change to your language code if needed, e.g. ara)
TESS_CONFIG=--oem 3 --psm 6 -l eng

# ── SBERT Embeddings ──

# Sentence-Transformer model name (downloaded automatically on first run).
# Lighter: sentence-transformers/all-MiniLM-L6-v2  (384-dim, faster)
# Default: sentence-transformers/all-mpnet-base-v2  (768-dim, best quality)
SBERT_MODEL_NAME=sentence-transformers/all-mpnet-base-v2

# ── Feature Flags ──

# Set to False to skip that modality (speeds up experimentation).
USE_IMAGE_EMBEDDINGS=True
USE_SENTENCE_TRANSFORMERS=True
USE_SPECIALIST_CLASSIFIERS=True

# ── Specialist Classifiers ──

# Number of confused class-pairs that get a dedicated binary specialist classifier.
N_CONFUSED_PAIRS=10


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 18: FUSION
#  Configuration for combining CNN and OCR predictions.
# ═══════════════════════════════════════════════════════════════════════════════

# Fusion strategies are configured within the fusion notebook itself.
# The following paths are used by the fusion notebook:

# Main fusion data folder (contains CNN predictions, OCR features, etc.)
# Already defined above as FUSION_DIR


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 19: LOGGING & VISUALIZATION
#  Settings for plot quality, confidence intervals, and training output.
# ═══════════════════════════════════════════════════════════════════════════════

# Wilson confidence interval alpha (0.05 = 95% confidence interval)
WILSON_CI_ALPHA=0.05

# DPI (dots per inch) for saved figures — higher = sharper but larger files
PLOT_DPI=600

# DPI for inline notebook figure display
NOTEBOOK_FIGURE_DPI=120

# Moving-average window size for smoothing training curve plots
SMOOTHING_WINDOW=3


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 20: PERFORMANCE & CUDA SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Enable cuDNN auto-tuner for optimal convolution algorithms on fixed-size inputs
# Set to False if input sizes vary significantly or for debugging
CUDNN_BENCHMARK=True

# Suppress all Python warnings during execution (useful for clean notebook output)
# Set to "default" to see warnings
WARNINGS_FILTER=ignore


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 21: ANALYSIS THRESHOLDS
#  Thresholds used in the final analysis to classify model performance
#  per class and recommend whether OCR fusion is needed.
# ═══════════════════════════════════════════════════════════════════════════════

# Per-class impact: classes with accuracy > OVERALL_ACC + IMPACT_THRESHOLD are "helps"
# and < OVERALL_ACC - IMPACT_THRESHOLD are "hurts"
IMPACT_THRESHOLD=0.05

# Classes with F1 below this are flagged as CRITICAL (OCR fusion required)
CRITICAL_F1_THRESHOLD=0.5

# Classes with best F1 across all models below this are flagged as WEAK
# (OCR fusion strongly recommended)
WEAK_F1_THRESHOLD=0.6

# Classes with best F1 below this are flagged as MODERATE (OCR fusion helpful)
MODERATE_F1_THRESHOLD=0.7

# When ensemble and best-single-model confidence gap is below this,
# ensemble prediction is preferred
ENSEMBLE_TIE_THRESHOLD=0.03


# ═══════════════════════════════════════════════════════════════════════════════
#  SECTION 22: PYTHON REQUIREMENTS
#  Key package dependencies for running all notebooks.
#  Install with:  pip install -r requirements.txt
